{
  "expo": {
    "name": "Rating Tracker",
    "slug": "Rating-Tracker",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/logo.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/startscreen.png",
      "resizeMode": "contain",
      "backgroundColor": "#1b1b21"
    },
    "updates": {
      "fallbackToCacheTimeout": 0
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.ratingTracker.ratingTracker",
      "infoPlist": {
        "UIBackgroundModes": ["remote-notification"]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/logo.png",
        "backgroundColor": "#FFFFFF"
      },
      "package": "com.ratingTracker.ratingTracker",
      "permissions": ["NOTIFICATIONS"]
    },
    "web": {
      "favicon": "./assets/logo.png"
    },
    "extra": {
      "eas": {
        "projectId": "3375cf41-739e-4a7b-bee7-24e9988365f0"
      }
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "icon": "./assets/logo.png",
          "color": "#1A1B1E",
          "sounds": ["./assets/notification.wav"]
        }
      ]
    ]
  }
}
