    "expo-build-properties": "~0.12.5",
    "expo-haptics": "~13.0.1",
    "expo-linear-gradient": "~13.0.2",
    "expo-notifications": "~0.28.19",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-native": "0.74.5",
    "react-native-gifted-charts": "^1.4.76",
    "react-native-pager-view": "6.3.0",
    "react-native-reanimated": "~3.10.1",
